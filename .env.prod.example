# Copy to .env (next to docker-compose.prod.yml) and edit before deploying.
# docker compose -f docker-compose.prod.yml automatically reads a file named .env

# Database
POSTGRES_USER=site_admin
POSTGRES_PASSWORD=change_me_to_something_strong
POSTGRES_DB=site_management

# Auth — MUST be changed for production
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Host port the web UI is published on (http://<pi-ip>:WEB_PORT)
WEB_PORT=5173
